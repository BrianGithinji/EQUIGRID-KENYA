# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api
VITE_EPRA_API_URL=https://api.epra.go.ke/v1
VITE_KPLC_API_URL=https://api.kplc.co.ke/v1

# Authentication
VITE_AUTH_ENABLED=false
VITE_API_KEY=your_api_key_here

# Feature Flags
VITE_USE_REAL_DATA=false
VITE_USE_ML_MODEL=false
VITE_USE_REAL_MAP=false

# Map Configuration
VITE_MAPBOX_TOKEN=your_mapbox_token_here
VITE_MAP_STYLE=mapbox://styles/mapbox/streets-v11

# Database (Backend)
DATABASE_URL=postgresql://user:password@localhost:5432/equigrid
REDIS_URL=redis://localhost:6379

# External APIs (Backend)
EPRA_API_KEY=your_epra_api_key
KPLC_API_KEY=your_kplc_api_key
KPLC_CLIENT_ID=your_client_id
KPLC_CLIENT_SECRET=your_client_secret

# ML Model
ML_MODEL_PATH=./models/tariff-predictor
USE_GPU=false
